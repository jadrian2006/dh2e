[
    {
        "name": "Extended Magazine",
        "type": "modification",
        "img": "systems/dh2e/icons/items/modification.svg",
        "system": {
            "description": "Modifies a ranged weapon's receiver to accept extended-capacity magazines in addition to standard ones. The weapon can use both normal and extended magazines interchangeably.\n\nInstallation requires a successful Ordinary (+10) Tech-Use test and takes 1d5 hours. Only one Extended Magazine modification can be fitted to a weapon.\n\n<strong>Solid Projectile:</strong> A widened magazine well with a dual-slot receiver, accommodating the longer extended box magazines.\n<strong>Las:</strong> An auxiliary power coupling spliced into the weapon's charge circuit, drawing from higher-capacity power packs.\n<strong>Bolt:</strong> A reinforced feed mechanism and expanded canister housing to handle the heavier extended bolt drums.\n<strong>Flame/Melta:</strong> An additional fuel line connection with a secondary valve, supporting the larger extended fuel canisters.\n<strong>Plasma:</strong> An enhanced capacitor bank wired into the weapon's containment field, interfacing with extended plasma flasks.",
            "source": "core",
            "availability": "average",
            "craftsmanship": "common",
            "weight": 0.5,
            "modType": "weapon",
            "slot": "general",
            "installTest": "tech-use",
            "installDifficulty": 10,
            "installTime": "1d5 hours",
            "rules": [
                {
                    "key": "FlatModifier",
                    "label": "Extended Magazine",
                    "domain": "magazine-capacity",
                    "value": "ceil(@item.system.magazine.max * 0.5)",
                    "source": "Extended Magazine"
                }
            ]
        }
    },
